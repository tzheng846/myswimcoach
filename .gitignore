.env
*.claude
*Kenneth
*.ipynb
*.csv
!processed/breaststroke_sample.csv
!processed/sample_br_1.csv
!processed/sample_br_2.csv
*CLAUDE.md
*.html
*.txt
!requirements.txt
/__pycache__/
/scripts
*.mp4
*.md
!README.md
/Side_above_water
/Side_underwater
/Side_water_level
/Breaststroke
/Front
/Pose
/as5600_logger_ble
/Aerial
/.paul

# landing/ is a web project — un-ignore the file types the rules above
# would otherwise swallow repo-wide (*.html, *.txt, *.md)
!/landing/**/*.html
!/landing/**/*.txt
!/landing/**/*.md

/as5600_logger_ble_esp32
/ESP_32_V5
/logger_esp32
/motor_logger_esp32
/as5600_logger_esp32
/supabase
/tests

# Track production-critical files the rules above would swallow (CODEBASE-AUDIT.md §5.3).
# Note: !supabase/*.sql alone would NOT work — git can't re-include files under an
# excluded directory, so the directory itself must be un-ignored.
!CLAUDE.md
!AGENTS.md
!CODEBASE-AUDIT.md
!/tests
!/ESP_32_V5
!/supabase

# Cache dirs at any depth (the /__pycache__/ rule above only matches the repo root)
__pycache__/
.pytest_cache/